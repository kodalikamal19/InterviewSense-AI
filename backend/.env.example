# InterviewSense AI Backend Environment Variables

# FastAPI server configuration
HOST=127.0.0.1
PORT=8000

# Security key for session validation or token signing (generate a secure random key in production)
SECRET_KEY=change_this_to_a_secure_random_key_before_deploying_or_running

# Database configuration (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interviewsense

# OpenAI API Key (Required for paid API services like resume matching, behavior analysis, and feedback reports)
OPENAI_API_KEY=your_openai_api_key_here

# Local file storage path for resumes and recordings
UPLOAD_DIR=./uploads

# Whisper model to use for local speech-to-text conversion (options: tiny, base, small, medium, large)
WHISPER_MODEL=base

# Hugging Face Token (Required for pyannote.audio speaker diarization models)
# You need to accept the license agreements for pyannote/speaker-diarization-3.1 and pyannote/segmentation-3.0 on Hugging Face
HF_TOKEN=your_huggingface_token_here
